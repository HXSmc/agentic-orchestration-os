#!/bin/bash
# glm-vision — offload a VISUAL task to GLM-4.6V (vision) instead of burning
# Claude/chrome-devtools usage. Sends image(s) + a prompt and prints the answer.
#
# Usage:
#   glm-vision "<prompt>" <image1> [image2 ...]
#
# IMPORTANT (verified 2026-07-12 by adversarial review): real vision works ONLY
# via the CODING endpoint (/api/coding/paas/v4/chat/completions) with OpenAI-style
# `image_url` data-URIs. The Anthropic endpoint (/api/anthropic) accepts glm-4.6v
# and the image but returns degenerate answers (ignored image → always "blue").
# Discriminator proof on the coding endpoint: solid RED→"red", GREEN→"green".
set -u
KEY_FILE="$HOME/.config/zai/api_key"
[ -r "$KEY_FILE" ] || { echo "glm-vision: missing $KEY_FILE" >&2; exit 78; }
[ "$#" -ge 2 ] || { echo "usage: glm-vision \"<prompt>\" <image> [image ...]" >&2; exit 64; }

PROMPT="$1"; shift
MODEL="${GLM_VISION_MODEL:-glm-4.6v}"
KEY="$(cat "$KEY_FILE")"

# Build the OpenAI-style content array (images as data-URIs, then the text).
BODY=$(python3 - "$MODEL" "$PROMPT" "$@" <<'PY'
import sys, json, base64, mimetypes, os
model, prompt = sys.argv[1], sys.argv[2]
content = []
for p in sys.argv[3:]:
    if not os.path.isfile(p):
        sys.stderr.write(f"glm-vision: no such image: {p}\n"); sys.exit(66)
    mt = mimetypes.guess_type(p)[0] or "image/png"
    with open(p, "rb") as f:
        b64 = base64.b64encode(f.read()).decode()
    content.append({"type": "image_url", "image_url": {"url": f"data:{mt};base64,{b64}"}})
content.append({"type": "text", "text": prompt})
print(json.dumps({"model": model, "max_tokens": 1500,
                  "messages": [{"role": "user", "content": content}]}))
PY
) || exit $?

RESP=$(curl -s --max-time 120 https://api.z.ai/api/coding/paas/v4/chat/completions \
  -H "Authorization: Bearer $KEY" -H "Content-Type: application/json" \
  -d "$BODY") || { echo "glm-vision: request failed" >&2; exit 1; }

echo "$RESP" | python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    sys.stderr.write("glm-vision: bad response\n"); sys.exit(1)
if "error" in d:
    sys.stderr.write("glm-vision error: " + json.dumps(d["error"])[:300] + "\n"); sys.exit(1)
msg = (d.get("choices") or [{}])[0].get("message", {}).get("content", "")
print((msg or "").strip())
'
